# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Database - default is local SQLite, zero config
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# --- To switch to MySQL later ---
# 1. npm install mysql2
# 2. set:
# DB_DIALECT=mysql
# DB_HOST=your-host
# DB_PORT=3306
# DB_NAME=your-db
# DB_USER=your-user
# DB_PASSWORD=your-password

# --- To switch to Azure SQL later ---
# 1. npm install tedious
# 2. set:
# DB_DIALECT=mssql
# DB_HOST=your-server.database.windows.net
# DB_PORT=1433
# DB_NAME=your-db
# DB_USER=your-user
# DB_PASSWORD=your-password

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
